{
  "name": "volunteer-manager-animecon",
  "version": "5.0.0",
  "description": "Volunteer Management environment for AnimeCon",
  "scripts": {
    "sync-db": "node ts-sql.build.mjs",
    "build": "next build",
    "build-prod": "node Docker.build.js 3001 volunteer-manager-docker",
    "build-staging": "node Docker.build.js 3002 volunteer-manager-staging",
    "build-turbo": "next build --turbopack",
    "build-with-bundle-analyzer": "cross-env ANALYZE=true next build",
    "serve": "next dev --turbo",
    "serve-with-scheduler": "cross-env APP_SCHEDULER_ENABLED=1 next dev --turbo",
    "lint": "biome check",
    "lint:fix": "biome lint --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnimeNL/volunteer-manager.git"
  },
  "author": "Peter Beverloo <peter@animecon.nl>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/AnimeNL/volunteer-manager#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "@mui/material": "$@mui/material"
  },
  "dependencies": {
    "@beverloo/volunteer-manager-timeline": "^3.1.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.50.1",
    "@mdxeditor/editor": "^3.55.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/x-charts-pro": "^9.0.2",
    "@mui/x-data-grid-pro": "^9.0.2",
    "@mui/x-date-pickers": "^9.0.2",
    "@mui/x-license": "^9.0.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "bowser": "^2.14.1",
    "cookie": "^1.1.1",
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.1",
    "dayjs": "^1.11.20",
    "mariadb": "^3.5.2",
    "marked": "^18.0.2",
    "mui-color-input": "^8.0.0",
    "mui-markdown": "^2.1.1",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "nuqs": "^2.8.9",
    "react": "^19.2.5",
    "react-avatar-editor": "15.1.0",
    "react-dom": "^19.2.5",
    "react-hook-form-mui": "^9.0.1",
    "scrypt-js": "^3.0.1",
    "set.prototype.symmetricdifference": "^1.1.3",
    "swr": "^2.4.1",
    "temporal-polyfill": "^0.3.2",
    "ts-sql-query": "^1.67.0",
    "twilio": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@simplewebauthn/typescript-types": "^8.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/d3-color": "^3.1.3",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-avatar-editor": "^13.0.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "next-build-id": "^3.0.0",
    "nodemailer-mock": "^2.0.10",
    "ts-sql-codegen": "^3.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "whatwg-fetch": "^3.6.20"
  }
}
