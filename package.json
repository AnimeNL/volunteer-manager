{
  "name": "volunteer-manager-animecon",
  "version": "5.0.0",
  "description": "AnimeCon Volunteer Manager",
  "scripts": {
    "sync-db": "node ts-sql.build.mjs",
    "build": "next build",
    "build-prod": "node Docker.build.js 3001 volunteer-manager-docker",
    "build-staging": "node Docker.build.js 3002 volunteer-manager-staging",
    "build-turbo": "next build --turbopack",
    "build-with-bundle-analyzer": "cross-env ANALYZE=true next build",
    "serve": "next dev --turbo",
    "serve-with-scheduler": "cross-env APP_SCHEDULER_ENABLED=1 next dev --turbo",
    "lint": "biome check",
    "lint:fix": "biome lint --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnimeNL/volunteer-manager.git"
  },
  "author": "Peter Beverloo <peter@animecon.nl>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/AnimeNL/volunteer-manager",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "@mui/material": "$@mui/material",
    "nodemailer-mock": {
      "nodemailer": "$nodemailer"
    }
  },
  "dependencies": {
    "@AnimeNL/volunteer-manager-timeline": "git+https://github.com/AnimeNL/volunteer-manager-timeline.git",
    "@google/genai": "^2.8.0",
    "@mdxeditor/editor": "^4.0.3",
    "@mui/icons-material": "^9.1.1",
    "@mui/lab": "^9.0.0-beta.5",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/x-charts-premium": "^9.5.0",
    "@mui/x-data-grid-premium": "^9.5.0",
    "@mui/x-date-pickers": "^9.5.0",
    "@mui/x-license": "^9.4.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "bowser": "^2.14.1",
    "cookie": "^1.1.1",
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.1",
    "dayjs": "^1.11.21",
    "mariadb": "^3.5.3",
    "marked": "^18.0.5",
    "mui-color-input": "^9.0.0",
    "mui-markdown": "^2.1.1",
    "next": "^16.2.9",
    "nodemailer": "^9.0.0",
    "nuqs": "^2.8.9",
    "react": "^19.2.7",
    "react-avatar-editor": "15.1.0",
    "react-dom": "^19.2.7",
    "react-hook-form-mui": "^9.0.1",
    "scrypt-js": "^3.0.1",
    "swr": "^2.4.1",
    "temporal-polyfill": "^0.3.2",
    "ts-sql-query": "^1.68.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@next/bundle-analyzer": "^16.2.9",
    "@simplewebauthn/typescript-types": "^8.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/d3-color": "^3.1.3",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-avatar-editor": "^13.0.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "next-build-id": "^3.0.0",
    "nodemailer-mock": "^2.0.11",
    "ts-sql-codegen": "^3.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
